# VeriChain Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# BLOCKCHAIN CONFIGURATION
# ===========================================

# Your MetaMask wallet private key (without 0x prefix)
# NEVER commit this to version control!
# Get this from MetaMask: Settings > Security & Privacy > Reveal Private Key
PRIVATE_KEY=your_wallet_private_key_here

# ===========================================
# RPC PROVIDERS (Choose one: Alchemy OR Infura)
# ===========================================

# Option 1: Alchemy (Recommended)
# Sign up at: https://www.alchemy.com/
# Create an app for Polygon network and copy the API key
REACT_APP_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Option 2: Infura
# Sign up at: https://infura.io/
# Create a project and copy the project ID
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here

# ===========================================
# POLYGON NETWORK RPC URLs
# ===========================================

# Polygon Amoy Testnet (recommended for testing - Mumbai is deprecated)
REACT_APP_POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_api_key

# Polygon Mumbai Testnet (Legacy - being deprecated)
REACT_APP_POLYGON_MUMBAI_RPC=https://polygon-mumbai.g.alchemy.com/v2/your_alchemy_api_key

# Polygon Mainnet (for production)
REACT_APP_POLYGON_MAINNET_RPC=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# ===========================================
# IPFS CONFIGURATION (Pinata)
# ===========================================

# Sign up at: https://www.pinata.cloud/
# Go to API Keys and create a new key with pinFileToIPFS and pinJSONToIPFS permissions

REACT_APP_PINATA_API_KEY=your_pinata_api_key_here
REACT_APP_PINATA_SECRET_KEY=your_pinata_secret_key_here
REACT_APP_PINATA_JWT=your_pinata_jwt_token_here

# Pinata Gateway URL (for retrieving files)
REACT_APP_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ===========================================
# SMART CONTRACT ADDRESSES
# ===========================================

# After deploying the contract, add the address here
# Deploy using: npm run deploy:amoy or npm run deploy:mumbai
REACT_APP_CONTRACT_ADDRESS=your_deployed_contract_address_here

# ===========================================
# POLYGONSCAN API KEY (for contract verification)
# ===========================================

# Sign up at: https://polygonscan.com/
# Go to API Keys and create a new key
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Default network (amoy, mumbai, or polygon)
REACT_APP_DEFAULT_NETWORK=amoy

# Chain ID for the default network
REACT_APP_CHAIN_ID=80002

# Enable demo mode (simulated blockchain when real connection fails)
REACT_APP_ENABLE_DEMO_MODE=true
